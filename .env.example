# Project secrets — copy to .env and fill in. Sourced automatically by
# update.sh; .env is gitignored.

# Mapbox public token for geocoding (https://account.mapbox.com).
# Falls back to Nominatim when unset, which is ~25× slower.
MAPBOX_ACCESS_TOKEN=

# Trafiklab ResRobot 2.1 API key for door-to-door transit routing to
# Odenplan (https://www.trafiklab.se → create project → add ResRobot 2).
# Free tier 30 000 calls/month. Without it, route.py leaves
# min_to_odenplan null on every row.
RESROBOT_KEY=

# Nominatim usage policy asks for a real contact email in the User-Agent
# header. Only used when MAPBOX_ACCESS_TOKEN is unset.
HEMNET_USER_AGENT='hemnet/1.0 (your-email@example.com)'
